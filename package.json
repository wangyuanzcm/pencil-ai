{
  "name": "my-monorepo",
  "private": true,
  "scripts": {
    "dev:desktop": "pnpm --filter @app/desktop dev",
    "build:desktop": "pnpm --filter @app/desktop build"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "turbo": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
