{
  "name": "@ha/schema",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./pen.schema.json": {
      "require": "./pen.schema.json",
      "import": "./pen.schema.json"
    },
    "./validator": {
      "require": "./dist/cjs/generated-validator.js",
      "import": "./dist/esm/generated-validator.js",
      "types": "./dist/types/generated-validator.d.ts"
    }
  },
  "scripts": {
    "build": "npm run generate && npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc --module commonjs --outDir dist/cjs",
    "build:esm": "tsc --module esnext --outDir dist/esm",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist/types",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:generated": "biome format --write src/generated-types-private.ts src/generated-types-public.ts",
    "generate": "npx tsx src/run-converter.ts && npm run format:generated && npx tsx src/run-markdown-converter.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0"
  }
}
