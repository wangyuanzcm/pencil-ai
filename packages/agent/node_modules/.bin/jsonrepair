#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/jsonrepair@3.13.3/node_modules/jsonrepair/node_modules:/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/jsonrepair@3.13.3/node_modules:/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/jsonrepair@3.13.3/node_modules/jsonrepair/node_modules:/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/jsonrepair@3.13.3/node_modules:/mnt/d/github_workspace/pencil-ai/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../jsonrepair/bin/cli.js" "$@"
else
  exec node  "$basedir/../jsonrepair/bin/cli.js" "$@"
fi
