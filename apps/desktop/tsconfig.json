{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["electron-vite/node", "vite/client"]
  },
  "include": ["src/**/*", "electron.vite.config.ts"],
  "exclude": ["node_modules", "dist"]
}
